{{>header}}
<title>Advance Poly Pathic Pharmaceuticals Limited</title>
{{>navbar}}
{{>hero}}

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-4">
          <div class="text-center mb-3">
            <img src="/public/img/Logo.jpg" alt="Company Logo" width="72" height="72" class="mb-3">
            <h5 class="fw-bold text-primary">Reset Password</h5>
            <p class="text-muted small">
              Enter your new password and confirm it to reset your account.
            </p>
          </div>
          
          {{#if errorMessage.password}}<p class="text-danger">{{errorMessage.password}}</p>{{/if}}


          <form id="forgetPassword3Form" action="/forget-password-3" method="post">
    <input type="hidden" name="recaptchaToken" id="forgetPassword3RecaptchaToken">
            <div class="form-floating mb-3">
              <input type="password" name="password"
                class="form-control border-2 {{#if errorMessage.password}}border-danger{{else}}border-primary{{/if}}"
                id="password" placeholder="New Password">
              <label for="password">New Password</label>
            </div>
            {{#if errorMessage.password}}
              <p class="text-danger">{{errorMessage.password}}</p>
            {{/if}}

            <div class="form-floating mb-3">
              <input type="password" name="confirmPassword"
                class="form-control border-2 {{#if errorMessage.confirmPassword}}border-danger{{else}}border-primary{{/if}}"
                id="confirmPassword" placeholder="Confirm Password">
              <label for="confirmPassword">Confirm Password</label>
            </div>
            {{#if errorMessage.confirmPassword}}
              <p class="text-danger">{{errorMessage.confirmPassword}}</p>
            {{/if}}

            <div class="d-grid">
              <button type="submit" class="btn btn-primary py-2">Reset Password</button>
            </div>
          </form>

          <div class="text-center mt-3">
            <a href="/login" class="text-decoration-none">Back to Login</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.getElementById("forgetPassword3Form").addEventListener("submit", function(e){

    e.preventDefault();

    grecaptcha.ready(function(){

        grecaptcha.execute(
            '6LcmCQ4tAAAAAEFDRP4OBVuOIptLKJkUUmKpBtmL',
            { action: 'forgot_password_step3' }
        ).then(function(token){

            document.getElementById("forgetPassword3RecaptchaToken").value = token;

            document.getElementById("forgetPassword3Form").submit();

        });

    });

});
</script>

{{>footer}}
