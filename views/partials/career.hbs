<!-- Career Start -->
<div class="container career py-5">
    <div class="row g-5 align-items-stretch">

        <!-- Left Side: Career Info -->
        <div class="col-xl-6 d-flex">
            <div class="wow fadeInUp" data-wow-delay="0.2s">
                <div class="bg-light rounded p-5 mb-5 w-100 h-100">
                    <h4 class="text-primary mb-4">Join Our Team</h4>
                    <p class="mb-4">
                        We are always looking for talented and passionate individuals to join our team. Explore
                        career opportunities and become a part of our growing organization.
                    </p>

                    <div class="row g-4">
                        <!-- Office -->
                        <div class="col-12">
                            <div class="career-add-item d-flex align-items-start mb-3">
                                <div class="career-icon text-primary me-3">
                                    <i class="fas fa-map-marker-alt fa-2x"></i>
                                </div>
                                <div>
                                    <h4 class="mb-1">Our Office</h4>
                                    <p class="mb-0">
                                        <a
                                            href="https://www.google.com/maps/place/Dr.+Mahesh+Sah+:+Best+Neuro+Hospital+in+Patna+:+Best+Orthopaedic+Surgery+in+Patna/@25.6204152,85.0429899,17z">
                                            Advance Polypath Pharmaceuticals Near Mahavir Hitech Hospital, Bailey Road,
                                            Saguna More, Vashi Kunj Apartment, Danapur, Patna, Bihar 801503
                                        </a>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Email -->
                        <div class="col-12">
                            <div class="career-add-item d-flex align-items-start mb-3">
                                <div class="career-icon text-primary me-3">
                                    <i class="fas fa-envelope fa-2x"></i>
                                </div>
                                <div>
                                    <h4 class="mb-1">Email Us</h4>
                                    <p class="mb-0">
                                        <a
                                            href="https://mail.google.com/mail/?view=cm&fs=1&to=advancepolypathpharmaceuticals@gmail.com">
                                            advancepolypathpharmaceuticals@gmail.com
                                        </a>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Phone -->
                        <div class="col-12">
                            <div class="career-add-item d-flex align-items-start mb-3">
                                <div class="career-icon text-primary me-3">
                                    <i class="fas fa-phone-volume fa-2x"></i>
                                </div>
                                <div>
                                    <h4 class="mb-1">Contact Number</h4>
                                    <p class="mb-0">
                                        <a href="tel:9199893278">9199893278</a>,
                                        <a href="tel:7677413112">7677413112</a>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- WhatsApp -->
                        <div class="col-12">
                            <div class="career-add-item d-flex align-items-start mb-3">
                                <div class="career-icon text-primary me-3">
                                    <i class="fa-brands fa-whatsapp fa-2x"></i>
                                </div>
                                <div>
                                    <h4 class="mb-1">WhatsApp</h4>
                                    <p class="mb-0">
                                        <a href="https://wa.me/9199893278" target="_blank">9199893278</a>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- LinkedIn -->
                        <div class="col-12">
                            <div class="career-add-item d-flex align-items-start mb-3">
                                <div class="career-icon text-primary me-3">
                                    <i class="fas fa-globe fa-2x"></i>
                                </div>
                                <div>
                                    <h4 class="mb-1">Website</h4>
                                    <p class="mb-0">
                                        <a href="https://advancepolypathpharmaceuticals.com" target="_blank">
                                            advancepolypathpharmaceuticals.com
                                        </a>
                                    </p>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side: Application Form -->
        <div class="col-xl-6 d-flex wow fadeInRight" data-wow-delay="0.2s">
            <div class="bg-light p-5 rounded w-100 h-100 wow fadeInUp" data-wow-delay="0.2s">
                <h4 class="text-primary mb-4">Apply Now</h4>
                <p class="mb-4">
                    Interested in joining our team? Fill out the form below and attach your resume.
                </p>

                {{#if show}}
                <div class="alert alert-success mt-3" role="alert">
                    <h5 class="fw-bold mb-2 text-success">🎉 Thank you for applying!</h5>
                    <p>
                        We have successfully received your application. Our recruitment team will carefully review your
                        application,
                        and if you are shortlisted, we will contact you promptly to schedule the next steps.
                    </p>
                    <p>
                        We truly appreciate your interest in joining our team and taking the time to submit your
                        application. Your skills and experience are valuable,
                        and we look forward to reviewing your submission carefully.
                    </p>
                </div>
                {{/if}}

                {{#if errorMessage.general}}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <strong>Error!</strong> {{errorMessage.general}}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                {{/if}}

                <form action="/career" method="post" enctype="multipart/form-data" id="careerForm">
                 <input type="hidden" name="recaptchaToken" id="registerRecaptchaToken">
                    <div class="row g-4">

                        <!-- Name Field -->
                        <div class="col-12">
                            <div class="form-floating">
                                <input type="text" name="name"
                                    class="form-control border-2 {{#if errorMessage.name}}border-danger is-invalid{{else}}border-primary{{/if}}"
                                    id="name" placeholder="Your Name" value="{{data.name}}">
                                <label for="name">Full Name *</label>
                                {{#if errorMessage.name}}
                                <div class="invalid-feedback d-block">
                                    <i class="fas fa-exclamation-circle"></i> {{errorMessage.name}}
                                </div>
                                {{/if}}
                            </div>
                        </div>

                        <!-- Email Field -->
                        <div class="col-12">
                            <div class="form-floating">
                                <input type="email" name="email"
                                    class="form-control border-2 {{#if errorMessage.email}}border-danger is-invalid{{else}}border-primary{{/if}}"
                                    id="email" placeholder="Your Email" value="{{data.email}}">
                                <label for="email">Email Address *</label>
                                {{#if errorMessage.email}}
                                <div class="invalid-feedback d-block">
                                    <i class="fas fa-exclamation-circle"></i> {{errorMessage.email}}
                                </div>
                                {{/if}}
                            </div>
                        </div>

                        <!-- Phone Field -->
                        <div class="col-12">
                            <div class="form-floating">
                                <input type="text" name="phone"
                                    class="form-control border-2 {{#if errorMessage.phone}}border-danger is-invalid{{else}}border-primary{{/if}}"
                                    id="phone" placeholder="Phone Number" value="{{data.phone}}">
                                <label for="phone">Phone Number *</label>
                                {{#if errorMessage.phone}}
                                <div class="invalid-feedback d-block">
                                    <i class="fas fa-exclamation-circle"></i> {{errorMessage.phone}}
                                </div>
                                {{/if}}
                            </div>
                        </div>

                        <!-- Position Field -->
                        <div class="col-12">
                            <div class="form-floating">
                                <input type="text" name="position"
                                    class="form-control border-2 {{#if errorMessage.position}}border-danger is-invalid{{else}}border-primary{{/if}}"
                                    id="position" placeholder="Position Applied For" value="{{data.position}}">
                                <label for="position">Position Applied For *</label>
                                {{#if errorMessage.position}}
                                <div class="invalid-feedback d-block">
                                    <i class="fas fa-exclamation-circle"></i> {{errorMessage.position}}
                                </div>
                                {{/if}}
                            </div>
                        </div>

                        <!-- Message Field -->
                        <div class="col-12">
                            <div class="form-floating">
                                <textarea name="message"
                                    class="form-control border-2 {{#if errorMessage.message}}border-danger is-invalid{{else}}border-primary{{/if}}"
                                    placeholder="Your Message" id="message"
                                    style="height: 120px;">{{data.message}}</textarea>
                                <label for="message">Message / Cover Letter *</label>
                                {{#if errorMessage.message}}
                                <div class="invalid-feedback d-block">
                                    <i class="fas fa-exclamation-circle"></i> {{errorMessage.message}}
                                </div>
                                {{/if}}
                            </div>
                        </div>

                        <!-- Resume Field -->
                        <div class="col-12">
                            <label for="resume"
                                class="form-label {{#if errorMessage.resume}}text-danger{{else}}text-primary{{/if}} fw-bold">
                                Upload Resume * (PDF, DOC, DOCX)
                            </label>
                            <input type="file"
                                class="form-control {{#if errorMessage.resume}}border-danger is-invalid{{/if}}"
                                id="resume" name="resume" accept=".pdf,.doc,.docx">
                            {{#if errorMessage.resume}}
                            <div class="invalid-feedback d-block">
                                <i class="fas fa-exclamation-circle"></i> {{errorMessage.resume}}
                            </div>
                            {{/if}}
                            <small class="form-text text-muted">Maximum file size: 5MB</small>
                        </div>

                        <div class="col-12">
                            <button type="submit" id="submitBtn" class="btn btn-primary w-100 py-3">
                                <span id="submitText">Submit Application</span>
                                <span id="submitSpinner" class="d-none ms-2">
                                    <i class="fas fa-spinner fa-spin"></i>
                                </span>
                            </button>
                        </div>

                        <div class="col-12">
                            <small class="text-muted">* Required fields</small>
                        </div>

                    </div>
                </form>
            </div>
        </div>

    </div>
</div>
<!-- Career End -->

<script>
    function handleSubmit() {
        const submitBtn = document.getElementById('submitBtn');
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Submitting...';

        return true;
    }
</script>
<script>
    document.getElementById('careerForm').addEventListener('submit', function () {
        const submitBtn = document.getElementById('submitBtn');
        const submitText = document.getElementById('submitText');
        const submitSpinner = document.getElementById('submitSpinner');

        submitBtn.disabled = true;
        submitText.textContent = 'Submitting...';
        submitSpinner.classList.remove('d-none');
    });

    window.addEventListener('load', function () {
        const submitBtn = document.getElementById('submitBtn');
        const submitText = document.getElementById('submitText');
        const submitSpinner = document.getElementById('submitSpinner');

        submitBtn.disabled = false;
        submitText.textContent = 'Submit Application';
        submitSpinner.classList.add('d-none');
    });
</script>

<script>
attachRecaptcha("careerForm","career");
</script>