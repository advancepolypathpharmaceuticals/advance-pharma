{{>header}}
<title>Advance Poly Pathic Pharmaceuticals Limited</title>
{{>navbar}}
{{>hero}}

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-4">
          <div class="text-center mb-3">
            <img src="/public/img/Logo.jpg" alt="Company Logo" width="72" height="72" class="mb-3">
            <h5 class="fw-bold text-primary">Verify OTP</h5>
            <p class="text-muted small">
              We’ve sent an OTP to your registered email.  
              Enter it below to continue resetting your password.
            </p>
          </div>

          {{#if errorMessage.reason}}<p class="text-danger">{{errorMessage.reason}}</p>{{/if}}

          <form id="forgetPassword2Form" action="/forget-password-2" method="post">
    <input type="hidden" name="recaptchaToken" id="forgetPassword2RecaptchaToken">
            <div class="form-floating mb-3">
              <input type="text" name="otp"
                class="form-control border-2 {{#if errorMessage.otp}}border-danger{{else}}border-primary{{/if}}"
                id="otp" placeholder="Enter OTP" value="{{data.otp}}">
              <label for="otp">Enter OTP</label>
            </div>

            {{#if errorMessage.otp}}
              <p class="text-danger">{{errorMessage.otp}}</p>
            {{/if}}

            <div class="d-grid">
              <button type="submit" class="btn btn-primary py-2">Verify OTP</button>
            </div>
          </form>

          <div class="text-center mt-3">
            <a href="/forget-password-1" class="text-decoration-none">Didn’t receive OTP? Resend</a>
            <br>
            <a href="/login" class="text-decoration-none">Back to Login</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.getElementById("forgetPassword2Form").addEventListener("submit", function(e){

    e.preventDefault();

    grecaptcha.ready(function(){

        grecaptcha.execute(
            '6LcmCQ4tAAAAAEFDRP4OBVuOIptLKJkUUmKpBtmL',
            { action: 'forgot_password_step2' }
        ).then(function(token){

            document.getElementById("forgetPassword2RecaptchaToken").value = token;

            document.getElementById("forgetPassword2Form").submit();

        });

    });

});
</script>
<script>
attachRecaptcha("forgetPasswordForm2", "forgot_password");
</script>
{{>footer}}
