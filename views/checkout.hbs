    border-color: #dc3545 !important;
    box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, .25);
  }

  .invalid-feedback {
    color: #dc3545;
    font-size: 13px;
    margin-top: 5px;
  }
</style>