{{>header}}
<title>Admin Dashboard | FAQ</title>
{{>navbar}}

{{>hero}}
<div class="container-fluid my-3">
    <div class="row">
        <div class="col-md-3 my-3">
            {{>sidebar}}
        </div>
        <div class="col-md-9 my-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="bg-primary text-center p-2 text-light flex-grow-1 me-3">Update FAQ</h5>
                <a href="/admin/faq" class="btn btn-outline-secondary btn-sm">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
            </div>
           
            <form action="/admin/faq/update/{{data._id}}" method="post">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="form-floating">
                            <input type="text" name="question" class="form-control border-2 border-primary"
                                placeholder="FAQ Question" value="{{data.question}}">
                                {{#if errorMessage.question}}
                                <p class="text-danger">{{errorMessage.question}}</p>
                                {{/if}}
                            <label>FAQ Question*</label>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="form-floating">
                            <input type="text" name="answer" class="form-control border-2 border-primary"
                                placeholder="FAQ Answer" value="{{data.answer}}" id="answer">
                                {{#if errorMessage.answer}}
                                <p class="text-danger">{{errorMessage.answer}}</p>
                                {{/if}}
                            <label for="answer">FAQ Answer*</label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <button type="submit" class="btn btn-primary w-100">Update</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
{{>footer}}