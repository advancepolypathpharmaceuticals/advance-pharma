{{>header}}
<title>Admin Dashboard | FAQ</title>
{{>navbar}}

{{>hero}}
<div class="container-fluid my-3">
    <div class="row">
        <div class="col-md-3 my-3">
            {{>sidebar}}
        </div>
        <div class="col-md-9 my-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="bg-primary text-center p-2 text-light flex-grow-1 me-3">FAQ</h5>
                <a href="/admin/faq/create" class="btn btn-outline-secondary btn-sm">
                    <i class="fa fa-plus"></i> Add FAQ
                </a>
            </div>

            <div class="table-responsive">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>-Id</th>
                            <th>FAQ Question</th>
                            <th>FAQ Answer</th>
                            <th>Edit</th>
                            <th>Delete</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each data}}
                        <tr>
                            <td>{{_id}}</td>
                            <td>{{question}}</td>
                            <td>{{answer}}</td>
                            <td>
                                <a href="/admin/faq/edit/{{_id}}"><i class="fa fa-edit text-primary fs-4"></i></a>
                            </td>
                            <td>
                                <a href="/admin/faq/delete/{{_id}}"><i class="fa fa-trash text-danger fs-4"></i></a>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{{>footer}}