{{>header}}
<title>My Profile</title>
{{>navbar}}
{{>hero}}
<div class="site-section my-5">
  <div class="container">
    <div class="row">
      <!-- Sidebar with Profile Picture -->
      <div class="col-md-3 mb-4">
        <!-- Profile Picture in Sidebar -->
        <div class="card text-center mb-4">
          <div class="card-body">
            <div class="profile-pic-container mx-auto mb-3">
              <img src="{{#if customer.pic}}/uploads/user/{{customer.pic}}{{else}}/img/default-profile.png{{/if}}" 
                   class="rounded-circle border" 
                   style="width: 100px; height: 100px; object-fit: cover;"
                   alt="Profile Picture">
            </div>
            <h6 class="card-title mb-1">{{customer.firstName}} {{customer.lastName}}</h6>
            <small class="text-muted">Customer</small>
          </div>
        </div>

        <div class="list-group">
          <a href="/customer" class="list-group-item list-group-item-action active">
            <i class="fas fa-tachometer-alt me-2"></i>Dashboard
          </a>
          <a href="/customer/orders" class="list-group-item list-group-item-action">
            <i class="fas fa-shopping-bag me-2"></i>Order History
          </a>
          <a href="/customer/profile" class="list-group-item list-group-item-action {{isActive '/customer/profile'}}">
            <i class="fas fa-user me-2"></i>My Profile
          </a>
          <a href="/logout" class="list-group-item list-group-item-action text-danger">
            <i class="fas fa-sign-out-alt me-2"></i>Logout
          </a>
        </div>
      </div>

      <!-- Main Content -->
      <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h2 class="text-primary">My Profile</h2>
        </div>

        {{#if success}}
        <div class="alert alert-success alert-dismissible fade show">
          <strong>Success!</strong> Your profile has been updated successfully.
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        {{/if}}

        <div class="card">
          <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-user-edit me-2"></i>Update Profile</h5>
          </div>
          <div class="card-body">
            <form action="/customer/profile/update" method="post" enctype="multipart/form-data">
              <!-- Profile Picture Section -->
              <div class="row mb-4">
                <div class="col-12">
                  <div class="text-center">
                    <div class="profile-pic-container mx-auto mb-3">
                      <img id="profilePicPreview" 
                           src="{{#if customer.pic}}/uploads/user/{{customer.pic}}{{else}}/img/default-profile.png{{/if}}" 
                           class="rounded-circle border" 
                           style="width: 150px; height: 150px; object-fit: cover; cursor: pointer;"
                           onclick="document.getElementById('profilePic').click()"
                           alt="Profile Picture">
                      <input type="file" id="profilePic" name="pic" 
                             class="d-none" accept="image/*" onchange="previewImage(this)">
                      <div class="mt-2">
                        <small class="text-muted">Click image to change profile picture (Optional)</small><br>
                        <small class="text-muted">JPEG, PNG, GIF, WebP - Max 2MB</small>
                      </div>
                    </div>
                    {{#if errorMessage.pic}}
                    <p class="text-danger text-center">{{errorMessage.pic}}</p>
                    {{/if}}
                  </div>
                </div>
              </div>

              <div class="row">
                <div class="col-md-6 mb-3">
                  <label for="firstName" class="form-label">First Name *</label>
                  <input type="text" class="form-control" id="firstName" name="firstName" 
                         value="{{customer.firstName}}" required>
                </div>
                <div class="col-md-6 mb-3">
                  <label for="lastName" class="form-label">Last Name *</label>
                  <input type="text" class="form-control" id="lastName" name="lastName" 
                         value="{{customer.lastName}}" required>
                </div>
              </div>

              <div class="row">
                <div class="col-md-6 mb-3">
                  <label for="email" class="form-label">Email Address</label>
                  <input type="email" class="form-control" id="email" name="email" 
                         value="{{customer.email}}" readonly disabled>
                  <small class="text-muted">Email cannot be changed</small>
                </div>
                <div class="col-md-6 mb-3">
                  <label for="phone" class="form-label">Phone Number *</label>
                  <input type="text" class="form-control" id="phone" name="phone" 
                         value="{{customer.phone}}" required>
                </div>
              </div>

              <h6 class="mt-4 mb-3 text-primary">Address Information</h6>
              
              <div class="mb-3">
                <label for="street" class="form-label">Street Address</label>
                <input type="text" class="form-control" id="street" name="street" 
                       value="{{customer.address.street}}">
              </div>

              <div class="row">
                <div class="col-md-6 mb-3">
                  <label for="city" class="form-label">City</label>
                  <input type="text" class="form-control" id="city" name="city" 
                         value="{{customer.address.city}}">
                </div>
                <div class="col-md-3 mb-3">
                  <label for="state" class="form-label">State</label>
                  <input type="text" class="form-control" id="state" name="state" 
                         value="{{customer.address.state}}">
                </div>
                <div class="col-md-3 mb-3">
                  <label for="zipCode" class="form-label">ZIP Code</label>
                  <input type="text" class="form-control" id="zipCode" name="zipCode" 
                         value="{{customer.address.zipCode}}">
                </div>
              </div>

              <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                  <i class="fas fa-save me-2"></i>Update Profile
                </button>
                <a href="/customer" class="btn btn-outline-secondary ms-2">
                  <i class="fas fa-times me-2"></i>Cancel
                </a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function previewImage(input) {
    const preview = document.getElementById('profilePicPreview');
    const file = input.files[0];
    
    if (file) {
        // Validate file type
        const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/webp'];
        if (!allowedTypes.includes(file.type)) {
            document.getElementById('admin-pic-error').innerText = "Invalid file type (Choice from JPEG, PNG, GIF, WebP)";
            input.value = '';
            return;
        }
        
        // Validate file size (2MB)
        if (file.size > 2 * 1024 * 1024) {
            document.getElementById('admin-pic-error').innerText = "Invalid file size (Image size must be less than 2MB)";
            input.value = '';
            return;
        }
        
        const reader = new FileReader();
        reader.onload = function(e) {
            preview.src = e.target.result;
        }
        reader.readAsDataURL(file);
    }
}
</script>

{{>footer}}