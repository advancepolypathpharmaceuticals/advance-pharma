{{>header}}
<title>My Orders - Order History</title>
{{>navbar}}
{{>hero}}
<div class="site-section my-5">
  <div class="container">
    <div class="row">
      <!-- Sidebar with Profile Picture -->
      <div class="col-md-3 mb-4">
        <!-- Profile Picture in Sidebar -->
        <div class="card text-center mb-4">
          <div class="card-body">
            <div class="profile-pic-container mx-auto mb-3">
              <img src="{{#if session.pic}}/uploads/user/{{session.pic}}{{else}}/img/default-profile.png{{/if}}" 
                   class="rounded-circle border" 
                   style="width: 100px; height: 100px; object-fit: cover;"
                   alt="Profile Picture">
            </div>
            <h6 class="card-title mb-1">{{session.name}}</h6>
            <small class="text-muted">Customer</small>
          </div>
        </div>

        <div class="list-group">
          <a href="/customer" class="list-group-item list-group-item-action">
            <i class="fas fa-tachometer-alt me-2"></i>Dashboard
          </a>
          <a href="/customer/orders" class="list-group-item list-group-item-action active">
            <i class="fas fa-shopping-bag me-2"></i>Order History
          </a>
          <a href="/customer/profile" class="list-group-item list-group-item-action">
            <i class="fas fa-user me-2"></i>My Profile
          </a>
          <a href="/logout" class="list-group-item list-group-item-action text-danger">
            <i class="fas fa-sign-out-alt me-2"></i>Logout
          </a>
        </div>
      </div>

      <!-- Main Content -->
      <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h2 class="text-primary">My Orders</h2>
          <a href="/service" class="btn btn-primary">
            <i class="fas fa-shopping-bag me-2"></i>Continue Shopping
          </a>
        </div>

        {{#if orders.length}}
          <div class="table-responsive">
            <table class="table table-hover">
              <thead class="table-light">
                <tr>
                  <th>Order #</th>
                  <th>Date</th>
                  <th>Items</th>
                  <th>Total</th>
                  <th>Status</th>
                  <th>Payment</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                {{#each orders}}
                <tr>
                  <td><strong>{{this.orderNumber}}</strong></td>
                  <td>{{dateHelper this.createdAt}}</td>
                  <td>{{this.items.length}} item(s)</td>
                  <td>{{formatPrice this.total}}</td>
                  <td>
                    <span class="badge bg-{{getStatusColor this.status}}">
                      <i class="fas fa-{{getStatusIcon this.status}} me-1"></i>
                      {{capitalize this.status}}
                    </span>
                  </td>
                  <td>
                    <span class="badge bg-{{getPaymentStatusColor this.paymentStatus}}">
                      <i class="fas fa-{{getPaymentStatusIcon this.paymentStatus}} me-1"></i>
                      {{capitalize this.paymentStatus}}
                    </span>
                  </td>
                  <td>
                    <a href="/customer/orders/{{this.orderNumber}}" class="btn btn-sm btn-outline-primary">
                      <i class="fas fa-eye me-1"></i>View
                    </a>
                  </td>
                </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        {{else}}
          <div class="text-center py-5">
            <i class="fas fa-shopping-bag fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">No Orders Yet</h4>
            <p class="text-muted mb-4">You haven't placed any orders yet.</p>
            <a href="/service" class="btn btn-primary btn-lg">
              <i class="fas fa-shopping-bag me-2"></i>Start Shopping
            </a>
          </div>
        {{/if}}
      </div>
    </div>
  </div>
</div>

{{>footer}}