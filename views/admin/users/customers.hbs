{{>header}}
<title>Admin Dashboard | Customers</title>
{{>navbar}}

{{>hero}}
<div class="container-fluid my-3">
    <div class="row">
        <div class="col-md-3 my-3">
            {{>sidebar}}
        </div>
        <div class="col-md-9 my-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="bg-success text-center p-2 text-light flex-grow-1 me-3">
                    <i class="fa fa-users me-2"></i>Customers Management
                </h5>
            </div>
            
            <div class="table-responsive">
                <table class="table table-bordered table-striped">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Profile</th>
                            <th>Username</th>
                            <th>Email</th>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>Phone</th>
                            <th>Role</th>
                            <th>Created At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each data}}
                        <tr>
                            <td>{{indexPlusOne @index}}</td>
                            <td class="text-center">
                                <img src="{{#if this.pic}}/uploads/user/{{this.pic}}{{else}}/img/default-profile.png{{/if}}" 
                                     class="rounded-circle" 
                                     style="width: 40px; height: 40px; object-fit: cover;"
                                     alt="{{this.username}}">
                            </td>
                            <td>{{this.username}}</td>
                            <td>{{this.email}}</td>
                            <td>{{this.firstName}}</td>
                            <td>{{this.lastName}}</td>
                            <td>{{this.phone}}</td>
                            <td>
                                <span class="badge bg-info">{{capitalize this.role}}</span>
                            </td>
                            <td>{{dateHelper this.createdAt}}</td>
                            <td>
                                <div class="btn-group">
                                    <a href="/admin/user/edit/{{this._id}}" class="btn btn-sm btn-outline-warning">
                                        <i class="fa fa-edit"></i>
                                    </a>
                                    <a href="/admin/user/delete/{{this._id}}" class="btn btn-sm btn-outline-danger" 
                                       onclick="return confirm('Are you sure you want to delete this customer?')">
                                        <i class="fa fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        {{else}}
                        <tr>
                            <td colspan="10" class="text-center text-muted py-4">
                                <i class="fa fa-users fa-3x mb-3"></i><br>
                                No customers found
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{{>footer}}