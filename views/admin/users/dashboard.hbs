{{>header}}
<title>Admin Dashboard</title>
{{>navbar}}

{{>hero}}
<div class="container-fluid my-4">
    <div class="row">
        <div class="col-md-3 my-3">
            {{>sidebar}}
        </div>
        <div class="col-md-9 my-3">
            <div class="row g-4">

                <!-- Profile Card -->
                <div class="col-md-4">
                    <div class="card shadow-sm border-0">
                        <img src="{{#if data.pic}}/uploads/user/{{data.pic}}{{else}}/img/default-profile.png{{/if}}"
                            class="card-img-top rounded-circle mx-auto mt-3" 
                            style="width: 200px; height: 200px; object-fit: cover;"
                            alt="profile">
                        <div class="card-body text-center">
                            <h5 class="card-title">{{data.firstName}} {{data.lastName}}</h5>
                            <p class="text-muted mb-1">{{capitalize data.role}}</p>
                            {{#if (isSuperAdmin session)}}
                            <a href="/admin/user" class="btn btn-primary btn-sm mt-2 w-100">
                                <i class="fas fa-users me-2"></i> Manage Users
                            </a>
                            {{/if}}
                        </div>
                    </div>
                </div>

                <!-- Details Card -->
                <div class="col-md-8">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-primary text-light">
                            <h5 class="mb-0"><i class="fas fa-user-cog me-2"></i> Admin Details</h5>
                        </div>
                        <div class="card-body">
                            <table class="table table-borderless mb-0">
                                <tbody>
                                    <tr>
                                        <th scope="row"><i class="fas fa-user me-2"></i> Username</th>
                                        <td>{{data.username}}</td>
                                    </tr>
                                    <tr>
                                        <th scope="row"><i class="fas fa-envelope me-2"></i> Email</th>
                                        <td>{{data.email}}</td>
                                    </tr>
                                    <tr>
                                        <th scope="row"><i class="fas fa-phone me-2"></i> Phone Number</th>
                                        <td>{{data.phone}}</td>
                                    </tr>
                                    <tr>
                                        <th scope="row"><i class="fas fa-calendar me-2"></i> Member Since</th>
                                        <td>{{dateHelper data.createdAt}}</td>
                                    </tr>
                                </tbody>
                            </table>
                            <div class="mt-3 text-center">
                                {{#if (isSuperAdmin session)}}
                                <a href="/admin/user/edit/{{data._id}}" class="btn btn-outline-primary mb-2">
                                    <i class="fas fa-edit me-2"></i> Edit Profile
                                </a>
                                {{/if}}
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
{{>footer}}