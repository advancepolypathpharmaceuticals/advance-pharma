{{>header}}
<title>Advance Poly Pathic Pharmaceuticals Limited</title>
{{>navbar}}
<div class="container-fluid bg-breadcrumb">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-8 text-center">
        <div class="card shadow border-0">
          <div class="card-body py-5">
            <div class="text-success mb-4">
              <i class="fas fa-check-circle fa-5x"></i>
            </div>

            <h2 class="text-success mb-3">Order Placed Successfully!</h2>
            <p class="lead mb-4">Thank you for your order. We have received your Cash on Delivery request.</p>

            <div class="alert alert-info mb-4">
              <h5><i class="fas fa-truck"></i> Cash on Delivery</h5>
              <p>Your Order Number: <strong>{{order.orderNumber}}</strong></p>
              <p class="mb-2">Please keep <strong>{{formatPrice order.total}}</strong> ready for the delivery executive.</p>
              <small>Our team will contact you shortly for order confirmation.</small>
            </div>

            <!-- Enhanced Order Summary -->
            <div class="card mb-4">
              <div class="card-header bg-light">
                <h6 class="mb-0"><i class="fas fa-receipt me-2"></i>Order Summary</h6>
              </div>
              <div class="card-body">
                <div class="row text-start">
                  <div class="col-6">Items Subtotal:</div>
                  <div class="col-6 text-end">{{formatPrice order.subtotal}}</div>
                  
                  {{#if order.discount}}
                    {{#if order.discount.amount}}
                    <div class="col-6 text-success">Coupon Discount 
                      {{#if order.discount.couponCode}}
                      ({{order.discount.couponCode}})
                      {{/if}}
                      :
                    </div>
                    <div class="col-6 text-end text-success">- {{formatPrice order.discount.amount}}</div>
                    
                    <div class="col-6">After Discount:</div>
                    <div class="col-6 text-end">{{formatPrice (subtract order.subtotal order.discount.amount)}}</div>
                    {{/if}}
                  {{/if}}
                  
                  <div class="col-6">Shipping:</div>
                  <div class="col-6 text-end">
                    {{#if (eq order.shipping 0)}}
                      <span class="text-success">FREE</span>
                    {{else}}
                      {{formatPrice order.shipping}}
                    {{/if}}
                  </div>
                  
                  <hr class="my-2">
                  
                  <div class="col-6"><strong>Final Amount:</strong></div>
                  <div class="col-6 text-end"><strong class="h5 text-primary">{{formatPrice order.total}}</strong></div>
                </div>
                
                {{#if order.discount}}
                  {{#if order.discount.amount}}
                  <div class="mt-3 p-2 bg-success bg-opacity-10 rounded text-center">
                    <small class="text-success">
                      <i class="fas fa-tag me-1"></i> 
                      You saved {{formatPrice order.discount.amount}} 
                      {{#if order.discount.couponCode}}
                      with coupon {{order.discount.couponCode}}
                      {{/if}}
                    </small>
                  </div>
                  {{/if}}
                {{/if}}
              </div>
            </div>

            <!-- Order Items -->
            <div class="card mb-4">
              <div class="card-header bg-light">
                <h6 class="mb-0"><i class="fas fa-shopping-bag me-2"></i>Order Items</h6>
              </div>
              <div class="card-body">
                {{#each order.items}}
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <div class="d-flex align-items-center">
                    <img src="/{{this.image}}" alt="{{this.name}}" 
                         style="width: 40px; height: 40px; object-fit: cover;" class="me-3">
                    <div>
                      <h6 class="mb-0">{{this.name}}</h6>
                      <small class="text-muted">Qty: {{this.quantity}}</small>
                    </div>
                  </div>
                  <div class="text-end">
                    <div>{{formatPrice this.total}}</div>
                    <small class="text-muted">{{formatPrice this.price}} each</small>
                  </div>
                </div>
                {{/each}}
              </div>
            </div>

            <div class="row mb-4">
              <div class="col-md-6">
                <div class="card bg-light">
                  <div class="card-body">
                    <h6><i class="fas fa-clock"></i> Next Steps</h6>
                    <small>1. Order confirmation call<br>2. Product packaging<br>3. Dispatch & delivery</small>
                  </div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="card bg-light">
                  <div class="card-body">
                    <h6><i class="fas fa-phone"></i> Need Help?</h6>
                    <small>Call us: 9199893278, 7677413112<br>Email: advancepolypathpharmaceuticals@gmail.com</small>
                  </div>
                </div>
              </div>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-center">
              <a href="/" class="btn btn-primary me-md-2">
                <i class="fas fa-home"></i> Continue Shopping
              </a>
              <a href="/contact" class="btn btn-outline-secondary">
                <i class="fas fa-headset"></i> Contact Support
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{{>footer}}