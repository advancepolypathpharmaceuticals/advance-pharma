{{>header}}
<title>Advance Poly Pathic Pharmaceuticals Limited</title>
{{>navbar}}
{{>hero}}

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-4">
          <div class="text-center mb-3">
            <img src="/public/img/Logo.jpg" alt="Company Logo" width="72" height="72" class="mb-3">
            <h5 class="fw-bold text-primary">Forgot Password</h5>
            <p class="text-muted small">Enter your username or email to receive an OTP.</p>
          </div>

          <form id="forgetPassword1Form" action="/forget-password-1" method="post">
    <input type="hidden" name="recaptchaToken" id="forgetPassword1RecaptchaToken">
          
            <div class="form-floating mb-3">
              <input type="text" name="username"
                class="form-control border-2 {{#if errorMessage.username}}border-danger{{else}}border-primary{{/if}}"
                id="username" placeholder="Username or Email" value="{{data.username}}">
              <label for="username">Username or Email</label>
            </div>

            {{#if errorMessage.username}}
              <p class="text-danger small">{{errorMessage.username}}</p>
            {{/if}}

            <div class="d-grid">
              <button type="submit" class="btn btn-primary py-2">Send OTP</button>
            </div>
          </form>

          <div class="text-center mt-3">
            <a href="/login" class="text-decoration-none">Back to Login</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.getElementById("forgetPassword1Form").addEventListener("submit", function(e){

    e.preventDefault();

    grecaptcha.ready(function(){

        grecaptcha.execute(
            '6LcmCQ4tAAAAAEFDRP4OBVuOIptLKJkUUmKpBtmL',
            { action: 'forgot_password_step1' }
        ).then(function(token){

            document.getElementById("forgetPassword1RecaptchaToken").value = token;

            document.getElementById("forgetPassword1Form").submit();

        });

    });

});
</script>

{{>footer}}
